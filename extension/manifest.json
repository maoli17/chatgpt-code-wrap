{
  "manifest_version": 3,
  "name": "ChatGPT Code Wrap",
  "version": "1.0.0",
  "description": "Add a per-block word wrap toggle to ChatGPT code blocks. No more horizontal scrolling!",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-code-wrap@maoli17.github.io",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
